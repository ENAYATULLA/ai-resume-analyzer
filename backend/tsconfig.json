{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "types": ["node"],

    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "5.0"
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}